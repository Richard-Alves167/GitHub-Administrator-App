{
  "expo": {
    "name": "GitHub Administrator App",
    "slug": "GitHub-App",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/images/logo/LogoGPVVerde.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./src/assets/images/logo/LogoGPVVerde.png",
      "resizeMode": "contain",
      "backgroundColor": "#2e2e2e"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/images/logo/LogoGPVVerde.png",
        "backgroundColor": "#2e2e2e"
      },
      "edgeToEdgeEnabled": true
    },
    "web": {
      "favicon": "../assets/images/logo/LogoGPVVerde.png"
    },
    "plugins": [
      "expo-video",
      "react-native-video"
    ]
  }
}
